model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  name           String
  role           Role            @default(TENANT)
  isBanned       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  properties     Property[]      
  rentalRequests RentalRequest[] 
  reviews        Review[]        

  @@map("users")
} 