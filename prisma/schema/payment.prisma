model Payment {
  id              String          @id @default(uuid())
  transactionId   String          @unique
  rentalRequestId String           @unique   
  rentalRequest   RentalRequest   @relation(fields: [rentalRequestId], references: [id], onDelete: Cascade)
  amount          Float
  provider        PaymentProvider // STRIPE or SSLCOMMERZ 
  status          PaymentStatus   @default(PENDING) // enums.prisma 
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("payments")
}